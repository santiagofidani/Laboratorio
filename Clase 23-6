Ejercicio 10)

using System;

class Program
{
    static void Main()
    {
        int[] numeros = new int[5];

        int opcion = 0;

        while (opcion != 5)
        {
            Console.WriteLine();
            Console.WriteLine("1 - Cargar vector");
            Console.WriteLine("2 - Mostrar vector");
            Console.WriteLine("3 - Buscar número");
            Console.WriteLine("4 - Sumar elementos");
            Console.WriteLine("5 - Salir");

            Console.Write("Opción: ");
            opcion = int.Parse(Console.ReadLine());

            if (opcion == 1)
            {
                for (int i = 0; i < numeros.Length; i++)
                {
                    Console.Write("Ingrese un número: ");
                    numeros[i] = int.Parse(Console.ReadLine());
                }
            }
            else if (opcion == 2)
            {
                foreach (int n in numeros)
                {
                    Console.Write(n + " ");
                }

                Console.WriteLine();
            }
            else if (opcion == 3)
            {
                Console.Write("Número a buscar: ");
                int buscado = int.Parse(Console.ReadLine());

                int posicion = -1;

                for (int i = 0; i < numeros.Length; i++)
                {
                    if (numeros[i] == buscado)
                    {
                        posicion = i;
                        break;
                    }
                }

                if (posicion != -1)
                {
                    Console.WriteLine("Encontrado en posición: " + posicion);
                }
                else
                {
                    Console.WriteLine("No encontrado");
                }
            }
            else if (opcion == 4)
            {
                int suma = 0;

                for (int i = 0; i < numeros.Length; i++)
                {
                    suma += numeros[i];
                }

                Console.WriteLine("Suma total: " + suma);
            }
            else if (opcion == 5)
            {
                Console.WriteLine("Programa finalizado.");
            }
            else
            {
                Console.WriteLine("Opción incorrecta.");
            }
        }
    }
}
