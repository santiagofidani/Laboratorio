Ejercicio 2)

using System;

class Program
{
    static void Main()
    {
        int[] numeros = new int[6];

        for (int i = 0; i < numeros.Length; i++)
        {
            Console.Write("Ingrese un número: ");
            numeros[i] = int.Parse(Console.ReadLine());
        }

        int pares = 0;
        int impares = 0;

        foreach (int n in numeros)
        {
            if (n % 2 == 0)
            {
                pares++;
            }
            else
            {
                impares++;
            }
        }

        Console.WriteLine("Pares: " + pares);
        Console.WriteLine("Impares: " + impares);
    }
}

Ejercicio 3)

using System;

class Program
{
    static void Main()
    {
        string[] ciudades =
        {
            "Madrid",
            "Buenos Aires",
            "Bogotá",
            "Lima",
            "Santiago"
        };

        Console.Write("Ingrese una ciudad: ");
        string buscada = Console.ReadLine();

        int posicion = -1;

        for (int i = 0; i < ciudades.Length; i++)
        {
            if (ciudades[i] == buscada)
            {
                posicion = i;
                break;
            }
        }

        if (posicion != -1)
        {
            Console.WriteLine("Ciudad encontrada en índice: " + posicion);
        }
        else
        {
            Console.WriteLine("Ciudad no encontrada");
        }
    }
}

Ejercicio 4)

using System;

class Program
{
    static void Main()
    {
        int[] notas = new int[5];
        int suma = 0;

        for (int i = 0; i < notas.Length; i++)
        {
            Console.Write("Ingrese una nota: ");
            notas[i] = int.Parse(Console.ReadLine());
        }

        for (int i = 0; i < notas.Length; i++)
        {
            suma += notas[i];
        }

        double promedio = (double)suma / notas.Length;

        Console.WriteLine("Promedio: " + promedio);

        if (promedio >= 6)
        {
            Console.WriteLine("Aprobado");
        }
        else
        {
            Console.WriteLine("Reprobado");
        }
    }
}

Ejercicio 5)

using System;

class Program
{
    static void Main()
    {
        int[] numeros = { 10, 20, 30, 40, 50, 0 };

        Console.Write("Ingrese un número: ");
        int nuevoValor = int.Parse(Console.ReadLine());

        int indiceInsertar = 2;

        for (int i = numeros.Length - 1; i > indiceInsertar; i--)
        {
            numeros[i] = numeros[i - 1];
        }

        numeros[indiceInsertar] = nuevoValor;

        Console.WriteLine("Vector resultante:");

        foreach (int n in numeros)
        {
            Console.Write(n + " ");
        }
    }
}

Ejercicio 6)

using System;

class Program
{
    static void Main()
    {
        string[] colores =
        {
            "Rojo",
            "Verde",
            "Azul",
            "Amarillo",
            "Negro"
        };

        Console.Write("Ingrese un índice (0 a 4): ");
        int indiceEliminar = int.Parse(Console.ReadLine());

        for (int i = indiceEliminar; i < colores.Length - 1; i++)
        {
            colores[i] = colores[i + 1];
        }

        colores[colores.Length - 1] = "";

        Console.WriteLine("Vector actualizado:");

        foreach (string color in colores)
        {
            Console.WriteLine(color);
        }
    }
}

