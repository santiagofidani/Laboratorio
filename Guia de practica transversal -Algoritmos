using System;

class Program
{
    static void Main()
    {
        string mejorNombre = "";
        double mejorNota = 0;
        double suma = 0;

        for (int i = 1; i <= 5; i++)
        {
            Console.Write("Nombre: ");
            string nombre = Console.ReadLine();

            Console.Write("Nota: ");
            double nota = Convert.ToDouble(Console.ReadLine());

            suma = suma + nota;

            if (i == 1 || nota > mejorNota)
            {
                mejorNota = nota;
                mejorNombre = nombre;
            }
        }

        Console.WriteLine("Promedio: " + (suma / 5));
        Console.WriteLine("Mejor alumno: " + mejorNombre);
        Console.WriteLine("Mejor nota: " + mejorNota);
    }
}


