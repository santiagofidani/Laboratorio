class Program
{
    static void Main()
    {
        int jugador1 = 0;
        int jugador2 = 0;

        for (int ronda = 1; ronda <= 3; ronda++)
        {
            Console.Write("Jugador 1 (piedra/papel/tijera): ");
            string j1 = Console.ReadLine();

            Console.Write("Jugador 2 (piedra/papel/tijera): ");
            string j2 = Console.ReadLine();

            if (
                (j1 == "piedra" && j2 == "tijera") ||
                (j1 == "papel" && j2 == "piedra") ||
                (j1 == "tijera" && j2 == "papel")
               )
            {
                jugador1++;
            }
            else if (
                (j2 == "piedra" && j1 == "tijera") ||
                (j2 == "papel" && j1 == "piedra") ||
                (j2 == "tijera" && j1 == "papel")
                    )
            {
                jugador2++;
            }
        }

        Console.WriteLine("Jugador 1 ganó: " + jugador1);
        Console.WriteLine("Jugador 2 ganó: " + jugador2);
    }
}


