using System;

public class HelloWorld
{
    static void Ejercicio1A()
{
    for (int i = 1; i <= 100; i++)
    {
        if (i % 3 == 0)
        {
            Console.WriteLine(i);
        }
    }
}

static void Ejercicio1B()
{
    Console.Write("Ingrese su edad: ");
    int edad = Convert.ToInt32(Console.ReadLine());

    if (edad < 18)
        Console.WriteLine("Menor de edad");
    else if (edad == 18)
        Console.WriteLine("Tiene justo 18");
    else
        Console.WriteLine("Mayor de edad");
}

static void Ejercicio1C()
{
    Console.Write("Ingrese una palabra: ");
    string palabra = Console.ReadLine();

    Console.WriteLine("Tiene " + palabra.Length + " letras");
}

static void Ejercicio1D()
{
    string clave = "alegracias";

    for (int i = 1; i <= 5; i++)
    {
        Console.Write("Ingrese la contraseña: ");
        string intento = Console.ReadLine();

        if (intento == clave)
        {
            Console.WriteLine("Correcta");
            break;
        }
    }
}

static void Ejercicio1E()
{
    int mayor = 0;

    for (int i = 1; i <= 10; i++)
    {
        Console.Write("Ingrese un número: ");
        int num = Convert.ToInt32(Console.ReadLine());

        if (i == 1 || num > mayor)
        {
            mayor = num;
        }
    }

    Console.WriteLine("El mayor es: " + mayor);
}

static void Ejercicio1F()
{
    Console.Write("Ingrese su nombre: ");
    string nombre = Console.ReadLine();

    Console.WriteLine("Hola " + nombre.ToUpper());
}

static void Ejercicio1G()
{
    for (int i = 1; i <= 10; i++)
    {
        Console.WriteLine("7 x " + i + " = " + (7 * i));
    }
}

static void Ejercicio1H()
{
    for (int i = 10; i >= 1; i--)
    {
        Console.WriteLine(i);
    }

    Console.WriteLine("oa");
}

static void Ejercicio1I()
{
    Console.Write("Ingrese un número: ");
    int num = Convert.ToInt32(Console.ReadLine());

    if (num % 2 == 0)
        Console.WriteLine("Par");
    else
        Console.WriteLine("Impar");
}

static void Ejercicio1J()
{
    Console.Write("Ingrese una frase: ");
    string frase = Console.ReadLine().ToLower();

    int contador = 0;

    foreach (char letra in frase)
    {
        if (letra == 'a' || letra == 'e' || letra == 'i' || letra == 'o' || letra == 'u')
        {
            contador++;
        }
    }

    Console.WriteLine("Cantidad de vocales: " + contador);
}

static void Ejercicio1K()
{
    Console.Write("Ingrese un número: ");
    int num = Convert.ToInt32(Console.ReadLine());

    for (int i = 1; i <= 12; i++)
    {
        Console.WriteLine(num + " x " + i + " = " + (num * i));
    }
}

static void Ejercicio1L()
{
    int suma = 0;

    while (suma <= 100)
    {
        Console.Write("Ingrese un número: ");
        suma += Convert.ToInt32(Console.ReadLine());
    }

    Console.WriteLine("Total acumulado: " + suma);
}

static void Ejercicio1M()
{
    Console.Write("Ingrese una palabra: ");
    string palabra = Console.ReadLine();

    foreach (char letra in palabra)
    {
        Console.WriteLine(letra);
    }
}

static void Ejercicio1N()
{
    Console.Write("Ingrese su edad: ");
    int edad = Convert.ToInt32(Console.ReadLine());

    if (edad >= 18)
        Console.WriteLine("Puede votar y manejar");
    else if (edad >= 16)
        Console.WriteLine("Puede votar");
    else
        Console.WriteLine("No puede ninguna");
}

static void Ejercicio1O()
{
    for (int i = 50; i >= 0; i -= 5)
    {
        Console.WriteLine(i);
    }
}

static void Ejercicio1P()
{
    string clave1;
    string clave2;

    do
    {
        Console.Write("Ingrese una contraseña: ");
        clave1 = Console.ReadLine();

        Console.Write("Repita la contraseña: ");
        clave2 = Console.ReadLine();

    } while (clave1 != clave2);

    Console.WriteLine("Acceso permitido");
}

static void Ejercicio1Q()
{
    string nombre;

    do
    {
        Console.Write("Ingrese un nombre: ");
        nombre = Console.ReadLine();

    } while (nombre.Length <= 10);

    Console.WriteLine("Fin del programa");
}

static void Ejercicio1R()
{
    Console.Write("Ingrese una oración: ");
    string oracion = Console.ReadLine().ToLower();

    int contador = 0;

    foreach (char letra in oracion)
    {
        if (letra == 'a')
        {
            contador++;
        }
    }

    Console.WriteLine("Cantidad de letras a: " + contador);
}


