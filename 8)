using System;

class Program
{
    static void Main()
    {
        double fahrenheit;
        double centigrados;

        Console.Write("Ingrese la temperatura en Fahrenheit: ");
        fahrenheit = Convert.ToDouble(Console.ReadLine());

        centigrados = (fahrenheit - 32) * 5 / 9;

        Console.WriteLine("Temperatura en grados centigrados: " + centigrados);
    }
}
